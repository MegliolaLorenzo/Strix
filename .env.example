# =============================================================================
# STRIX - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your API keys.
# Never commit the .env file to version control.

# --- LLM Provider ---
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Search Provider ---
# Get your key at: https://app.tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# --- News Provider ---
# Get your key at: https://gnews.io/
GNEWS_API_KEY=your_gnews_api_key_here

# --- Backend ---
STRIX_HOST=127.0.0.1
STRIX_PORT=8000
STRIX_DB_PATH=strix.db

# --- Helper App ---
# Default global shortcut (can also be changed in helper settings)
STRIX_SHORTCUT=CommandOrControl+Shift+X
