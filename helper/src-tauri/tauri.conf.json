{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "STRIX",
  "version": "0.1.0",
  "identifier": "com.strix.helper",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "STRIX",
        "width": 440,
        "height": 520,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "label": "main"
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "STRIX - Fact Checker"
    },
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "global-shortcut": {
      "shortcuts": ["CommandOrControl+Shift+X"]
    }
  }
}
